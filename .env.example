# Copy to .env.local and fill in from the Supabase dashboard
# (Project Settings → API). The anon key is safe to expose client-side;
# row-level security policies are the actual access control.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: forward runtime errors as JSON POSTs to a collector
# (Slack webhook, Supabase edge function, etc.). Leave unset to disable.
# VITE_ERROR_WEBHOOK_URL=
